# PostgreSQL
POSTGRES_DB=EmirOtomotivDb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# JWT — use a long random string (min 32 chars)
JWT_SECRET=change_this_to_a_very_long_random_secret_key

# CORS — comma-separated allowed origins for the API
# In Docker the client nginx proxies /api/* so usually same host is enough
CORS_ORIGINS=http://localhost
